#!/bin/bash
# Pre-commit hook to prevent secrets from being committed

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
[ -z "$STAGED_FILES" ] && exit 0

echo -e "${YELLOW}Scanning for secrets...${NC}"

FOUND=0

# Secret patterns
PATTERNS=(
    'sk-[a-zA-Z0-9]{20,}'
    'ghp_[a-zA-Z0-9]{36}'
    'gho_[a-zA-Z0-9]{36}'
    'ghu_[a-zA-Z0-9]{36}'
    'github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}'
    'AKIA[0-9A-Z]{16}'
    'ya29\.[a-zA-Z0-9_-]{100,}'
    'AIza[0-9A-Za-z_-]{35}'
    'xox[baprs]-[0-9a-zA-Z]{10,}'
    'npm_[a-zA-Z0-9]{36}'
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
    '-----BEGIN PGP PRIVATE KEY BLOCK-----'
    'https?://[^:]+:[^@]+@[^/]+'
    'mongodb(\+srv)?://[^:]+:[^@]+@'
    'postgres(ql)?://[^:]+:[^@]+@'
    'mysql://[^:]+:[^@]+@'
    'redis://[^:]+:[^@]+@'
    'eyJ[a-zA-Z0-9_-]{10,}\.eyJ[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]{10,}'
)

for file in $STAGED_FILES; do
    [[ "$file" =~ \.(png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|pdf|zip|tar|gz)$ ]] && continue
    [[ "$file" =~ ^\.husky/ ]] && continue
    [ ! -f "$file" ] && continue
    
    for pattern in "${PATTERNS[@]}"; do
        matches=$(git diff --cached "$file" | grep -E "$pattern" 2>/dev/null || true)
        if [ -n "$matches" ]; then
            echo -e "${RED}⚠️  Secret in: $file${NC}"
            echo -e "${RED}   Pattern: $pattern${NC}"
            echo "$matches" | head -3
            FOUND=1
        fi
    done
done

# Check suspicious files
SUS=$(echo "$STAGED_FILES" | grep -iE '\.(pem|key|p12|pfx|keystore|jks)$|^\.env$|\.env\.|secrets?\.(json|ya?ml|toml)|credentials|\.secret' || true)
if [ -n "$SUS" ]; then
    echo -e "${RED}⚠️  Suspicious files:${NC}"
    echo "$SUS"
    FOUND=1
fi

if [ $FOUND -eq 1 ]; then
    echo -e "${RED}❌ Commit blocked${NC}"
    echo -e "${YELLOW}Bypass: git commit --no-verify${NC}"
    exit 1
fi

echo -e "${GREEN}✓ No secrets${NC}"
