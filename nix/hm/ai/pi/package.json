{
  "name": "pi-hm-extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "pnpm --package=oxfmt@latest dlx oxfmt --write .",
    "format:check": "pnpm --package=oxfmt@latest dlx oxfmt .",
    "lint": "pnpm --package=oxlint-tsgolint@latest dlx oxlint --type-aware --type-check -f stylish --tsconfig tsconfig.json .",
    "lint:file": "pnpm --package=oxlint-tsgolint@latest dlx oxlint --type-aware --type-check -f stylish --tsconfig tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@sinclair/typebox": "^0.34.48",
    "exa-js": "^2.3.0",
    "picomatch": "^4.0.3",
    "shell-quote": "^1.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/picomatch": "^4.0.2",
    "@types/shell-quote": "^1.7.5",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "latest",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
